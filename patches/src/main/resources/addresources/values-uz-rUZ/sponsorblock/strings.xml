  <string name="morphe_sb_segments_sponsor">Homiylar</string>
  <string name="morphe_sb_segments_sponsor_summary">Pullik reklama, pullik tavsiyalar va to\'g\'ridan-to\'g\'ri reklama. O\'z-o\'zini targ\'ib qilish yoki ular yaxshi ko\'radigan sabablar/ijodkorlar/vebsaytlar/mahsulotlarga bepul reklama uchun emas</string>
  <string name="morphe_sb_segments_selfpromo">Pullik bo\'lmagan / O\'z-o\'zini targ\'ib qilish</string>
  <string name="morphe_sb_segments_selfpromo_summary">Sponsordan farqli o\'laroq pullik bo\'lmagan / o\'z-o\'zini targ\'ib qilish. Mahsulotlar, donatsiyalar yoki ular kim bilan hamkorlik qilgani haqidagi bo\'limlarni o\'z ichiga oladi</string>
  <string name="morphe_sb_segments_interaction">O\'zaro ta\'sir eslatmasi (O\'qish)</string>
  <string name="morphe_sb_segments_interaction_summary">Kontent o\'rtasida yoqish, obuna bo\'lish yoki ularga ergashish bo\'yicha qisqa eslatma. U uzun bo\'lsa yoki biror narsa haqida bo\'lsa, u o\'z-o\'zini targ\'ib qilish ostida bo\'lishi kerak</string>
  <string name="morphe_sb_segments_highlight">Muhim jihat</string>
  <string name="morphe_sb_segments_highlight_summary">Videoning eng qiziqarli qismi</string>
  <string name="morphe_sb_segments_intro">Tanaffus / Kirish animatsiyasi</string>
  <string name="morphe_sb_segments_intro_summary">Haqiqiy kontent bo\'lmagan oraliq. Pauza, statik ramka yoki takroriy animatsiya bo\'lishi mumkin. Ma\'lumotlarni o\'z ichiga olgan o\'tishlar kirmaydi</string>
  <string name="morphe_sb_segments_outro">Yakuniy kartalar / Kreditlar</string>
  <string name="morphe_sb_segments_outro_summary">Kreditlar yoki YouTube yakuniy kartalari paydo bo\'lganda. Ma\'lumotlarni o\'z ichiga olgan xulosalar uchun emas</string>
  <string name="morphe_sb_segments_hook">Boshlanish / Salomlashish</string>
  <string name="morphe_sb_segments_hook_summary">Kelgusi video treylerlari, salomlashish va xayrlashish. Qo\'shimcha ma\'lumotlar beradigan bo\'limlarni o\'z ichiga olmaydi</string>
  <string name="morphe_sb_segments_preview">Oldindan ko\'rish / Esda saqlash</string>
  <string name="morphe_sb_segments_preview_summary">Kelgusi videoda nima bo\'lishini yoki seriyadagi boshqa videolarda nima bo\'lishini ko\'rsatuvchi kliplar to\'plami, barcha ma\'lumotlar boshqa joylarda takrorlangan</string>
  <string name="morphe_sb_segments_filler">Chekka / Hazillar</string>
  <string name="morphe_sb_segments_filler_summary">Videoning asosiy mazmunini tushunish uchun zarur bo\'lmagan chekka sahnalar yoki hazillar. Kontekst yoki orqa fon tafsilotlarini beruvchi bo\'limlarni o\'z ichiga olmaydi</string>
  <string name="morphe_sb_segments_nomusic">Musiqa: Musiqasiz bo\'lim</string>
  <string name="morphe_sb_segments_nomusic_summary">Faqat musiqali videolarda ishlatiladi. Musiqa bo\'lmagan musiqali videolar bo\'limlari, boshqa toifalar bilan qamrab olinmagan</string>
